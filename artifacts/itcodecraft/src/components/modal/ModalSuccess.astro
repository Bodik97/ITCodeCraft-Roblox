---
import content from "@/data/data.json";
---

<div id="modal-success" class="hidden fixed inset-0 z-[200] items-center justify-center bg-black/50 p-4" role="dialog" aria-modal="true">
  <div class="bg-white rounded-2xl p-8 max-w-md text-center shadow-xl">
    <h3 class="text-xl font-bold text-[#00B06F] mb-2">{content.modal.successTitle}</h3>
    <p class="text-slate-600 text-sm">{content.modal.successMessage}</p>
    <button type="button" id="modal-success-close" class="mt-6 px-6 py-2 rounded-xl btn-3d-amber font-bold">OK</button>
  </div>
</div>

<script>
  import { lockBodyScroll, unlockBodyScroll } from "@/lib/scrollLock";

  const modal = document.getElementById("modal-success");

  function setSuccessModalOpen(open: boolean) {
    if (!modal) return;
    modal.classList.toggle("hidden", !open);
    modal.classList.toggle("flex", open);
    if (open) lockBodyScroll();
    else unlockBodyScroll();
  }

  window.addEventListener("itcc:form-success", () => setSuccessModalOpen(true));
  document.getElementById("modal-success-close")?.addEventListener("click", () => setSuccessModalOpen(false));
</script>
