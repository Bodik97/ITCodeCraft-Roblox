---
import content from "@/data/data.json";

interface Props {
  size?: "md" | "sm";
  href?: string;
  class?: string;
  variant?: "dark" | "light";
}

const {
  size = "md",
  href = content.brand.homeUrl,
  class: className = "",
  variant = "dark",
} = Astro.props;

const isSmall = size === "sm";
const brandPrimary = content.brand.primary;
const brandAccent = content.brand.accent;
const brandPrefix = brandPrimary.startsWith("IT") ? "IT" : brandPrimary.slice(0, 2);
const brandBase = brandPrimary.slice(brandPrefix.length);
const variantClass = variant === "light" ? "ic-logo--light" : "";
---

<a
  href={href}
  aria-label={`${brandPrimary}${brandAccent}`}
  class:list={["ic-logo", isSmall ? "ic-logo--sm" : "ic-logo--md", variantClass, className]}
>
  <span class="ic-wordmark">
    <span class="ic-name">
      <span class="ic-name-prefix">{brandPrefix}</span><span class="ic-name-base">{brandBase}</span><span
        class="ic-name-accent">{brandAccent}</span
      >
    </span>
    <span class="ic-subline">IT SCHOOL · ONLINE</span>
  </span>
</a>
