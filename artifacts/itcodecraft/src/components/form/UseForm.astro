---
import LeadForm from "./Form";
import content from "@/data/data.json";

interface Props {
  formId?: string;
}

const { formId } = Astro.props;
const { registerSection, crm } = content;
const crmWithFormId = formId ? { ...crm, formId } : crm;
---

<LeadForm client:idle copy={registerSection.form} crm={crmWithFormId} />
