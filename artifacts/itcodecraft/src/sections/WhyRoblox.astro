---
import content from "@/data/data.json";
const s = content.whySection;
---

<section class="py-20 bg-[#F9FAFB]">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14 fade-in-up">
      <span class="inline-block bg-[#00A2FF]/10 text-[#00A2FF] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">{s.eyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-[#0F172A] mb-3">{s.title}</h2>
      <p class="text-slate-500 text-lg max-w-xl mx-auto">{s.subtitle}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {s.items.map((item) => (
        <article class="fade-in-up bg-white p-7 rounded-2xl shadow-sm border border-slate-100 text-center">
          <div class="text-2xl font-display font-bold text-[#0F172A] mb-1">{item.stat}</div>
          <div class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">{item.sub}</div>
          <p class="text-slate-600 text-sm leading-relaxed">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
