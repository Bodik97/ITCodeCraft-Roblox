---
import { Image } from "astro:assets";
import content from "@/data/data.json";
import { getAsset } from "@/lib/assets";

const s = content.mentorsSection;
---

<section id="mentors" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14 fade-in-up">
      <span class="inline-block bg-[#6366F1]/10 text-[#6366F1] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">{s.eyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-[#0F172A] mb-3">{s.title}</h2>
      <p class="text-slate-500 text-lg max-w-xl mx-auto">{s.subtitle}</p>
    </div>
    <div class="grid md:grid-cols-3 gap-7 max-w-5xl mx-auto">
      {s.mentors.map((m) => (
        <article class="fade-in-up bg-slate-50 rounded-2xl border border-slate-100 overflow-hidden">
          <div class="relative h-52 overflow-hidden">
            <Image src={getAsset(m.image)} alt={`Викладач ${m.name}`} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-6">
            <p class="font-display font-bold text-[#0F172A] text-lg">{m.name}</p>
            <p class="text-[#00A2FF] text-sm font-bold">{m.role}</p>
            <blockquote class="text-slate-600 text-sm italic leading-relaxed border-l-2 border-[#6366F1]/30 pl-3 mt-4">&ldquo;{m.quote}&rdquo;</blockquote>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
