---
import { Image } from "astro:assets";
import content from "@/data/data.json";
import { getAsset } from "@/lib/assets";

const s = content.gamesSection;
---

<section id="course" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14 fade-in-up">
      <span class="inline-block bg-[#6366F1]/10 text-[#6366F1] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">{s.eyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-[#0F172A] mb-3">{s.title}</h2>
      <p class="text-slate-500 text-lg max-w-xl mx-auto">{s.subtitle}</p>
    </div>
    
    <!-- Змінено grid-cols-2 на grid-cols-1 md:grid-cols-2 lg:grid-cols-3 для кращого вигляду 6+ ігор -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {
        s.games.map((game, index) => (
          <article 
            class="fade-in-up course-card rounded-2xl border-2 border-slate-100 bg-white overflow-hidden group"
            style={`animation-delay: ${index * 0.2}s; animation-duration: 1.2s;`} 
          >
            <!-- index * 0.2s робить появу кожної наступної гри повільнішою -->
            <div class="relative h-48 overflow-hidden">
              <Image 
                src={getAsset(game.image)} 
                alt={`Приклад гри: ${game.title}`} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
                loading="lazy" 
              />
              <div class="absolute top-3 left-3 flex gap-2">
                <span class="bg-white/90 backdrop-blur px-2 py-0.5 rounded-full text-xs font-bold text-[#6366F1]">{game.duration}</span>
                <span class={`${game.diffClass} px-2 py-0.5 rounded-full text-xs font-bold`}>{game.difficulty}</span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-display font-bold text-[#0F172A] mb-2">{game.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{game.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .fade-in-up {
    opacity: 0;
    animation: fadeInUp ease forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>