---
import content from "@/data/data.json";
const s = content.howItWorksSection;
---

<section id="how-it-works" class="py-20 bg-white">
  <div class="container mx-auto px-4 max-w-3xl">
    <div class="text-center mb-14 fade-in-up">
      <span class="inline-block bg-[#6366F1]/10 text-[#6366F1] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">{s.eyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-[#0F172A] mb-3">{s.title}</h2>
      <p class="text-slate-500 text-lg">{s.subtitle}</p>
    </div>
    <div class="relative">
      <div class="timeline-line" aria-hidden="true"></div>
      <div class="space-y-6">
        {s.steps.map((item, i) => (
          <article class="fade-in-up relative flex gap-6 items-start">
            <div class="relative z-10 w-10 h-10 rounded-xl bg-[#6366F1] text-white font-bold text-sm flex items-center justify-center shrink-0">{i + 1}</div>
            <div class="flex-1 bg-white border-2 border-slate-100 rounded-2xl p-5">
              <div class="text-[10px] font-bold text-[#6366F1] uppercase tracking-widest mb-1">{item.step}</div>
              <h3 class="text-base font-display font-bold text-[#0F172A] mb-0.5">{item.title}</h3>
              <p class="text-slate-500 text-sm">{item.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
