---
import TestimonialsCarousel from "@/components/TestimonialsCarousel";
import content from "@/data/data.json";
const s = content.testimonialsSection;
---

<section class="py-20 bg-[#F9FAFB] overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14 fade-in-up">
      <span class="inline-block bg-[#FBBF24]/20 text-amber-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">{s.eyebrow}</span>
      <h2 class="text-3xl md:text-4xl font-display font-bold text-[#0F172A]">{s.title}</h2>
    </div>
    <TestimonialsCarousel client:visible items={s.items} />
  </div>
</section>
