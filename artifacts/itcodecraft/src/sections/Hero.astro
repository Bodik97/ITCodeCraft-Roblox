---
import content from "@/data/data.json";
import RobloxCharacter from "@/components/RobloxCharacter.astro";

const h = content.hero;
const particles = [
  { size: 8, left: "12%", delay: "0s", duration: "14s", color: "#6366F1" },
  { size: 5, left: "28%", delay: "2.5s", duration: "11s", color: "#FBBF24" },
  { size: 10, left: "45%", delay: "1.2s", duration: "16s", color: "#00A2FF" },
];
---

<section class="bg-[#0F172A] text-white pt-16 pb-20 overflow-hidden relative">
  {
    particles.map((p) => (
      <div
        class="hero-particle"
        style={`width:${p.size}px;height:${p.size}px;left:${p.left};bottom:-20px;background:${p.color};animation-delay:${p.delay};animation-duration:${p.duration};opacity:0`}
        aria-hidden="true"
      />
    ))
  }
  <div class="container mx-auto px-4 grid lg:grid-cols-2 gap-8 items-center relative z-10">
    <div class="space-y-7 fade-in-up">
      <div class="inline-flex items-center gap-2 bg-white/10 px-4 py-2 rounded-full border border-white/20 text-sm font-medium">
        <span class="w-2 h-2 rounded-full bg-[#00B06F] animate-pulse" />
        {h.badge}
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold leading-tight">
        {h.titlePrefix}
        <span class="text-[#00A2FF]">{h.titleHighlight}</span>
        {h.titleSuffix}
      </h1>
      <p class="text-lg text-slate-300 max-w-xl leading-relaxed">{h.description}</p>
      <div class="flex flex-col sm:flex-row gap-3">
        <button type="button" data-scroll-to="cta" class="px-7 py-4 rounded-xl font-display font-bold text-base btn-3d-amber">
          {h.primaryCta}
        </button>
        <button type="button" data-scroll-to="games" class="px-7 py-4 rounded-xl font-bold text-base bg-white/10 hover:bg-white/20 border border-white/20">
          {h.secondaryCta}
        </button>
      </div>
    </div>
    <div class="hidden lg:flex justify-center">
      <RobloxCharacter />
    </div>
  </div>
</section>
