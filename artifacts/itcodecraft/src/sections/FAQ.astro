---
import content from "@/data/data.json";
const s = content.faqSection;

// Автоматично або вручну групуємо елементи для зручності (можна за ключовими словами)
const categories = [
  { id: "general", name: "Про навчання" },
  { id: "languages", name: "Програми та мови" },
  { id: "tech-price", name: "Оплата та тех. питання" }
];

// Розподіляємо твої 11 питань за категоріями для фокусування уваги
const getCategoryItems = (catId: string) => {
  if (catId === "general") {
    return s.items.filter((_, i) => [0, 1, 2, 4].includes(i));
  }
  if (catId === "languages") {
    return s.items.filter((_, i) => [3, 8].includes(i));
  }
  return s.items.filter((_, i) => [5, 6, 7, 9, 10].includes(i));
};
---

<section id="faq" class="py-16 md:py-24 bg-white relative overflow-hidden">
  <div class="absolute top-0 right-0 w-1/3 h-1/3 bg-blue-50/50 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-1/3 bg-purple-50/50 rounded-full blur-[120px] -z-10 pointer-events-none"></div>

  <div class="container mx-auto px-4 max-w-4xl relative">
    
    <div class="text-center mb-10 reveal">
      <div class="inline-block px-4 py-1.5 bg-[#6366F1]/5 border border-[#6366F1]/10 rounded-full mb-4">
        <span class="text-[#6366F1] text-[10px] md:text-xs font-bold uppercase tracking-widest">{s.eyebrow}</span>
      </div>
      <h2 class="text-2xl md:text-4xl font-display font-bold text-[#0F172A] leading-tight mb-2">
        {s.title}
      </h2>
    </div>

    <div class="flex justify-center p-1 bg-slate-100 rounded-2xl max-w-xl mx-auto mb-10 reveal">
      {categories.map((cat, idx) => (
        <button
          data-tab-target={cat.id}
          class={`tab-btn cursor-pointer flex-1 py-3 text-center text-xs md:text-sm font-bold rounded-xl transition-all duration-300 ${idx === 0 ? 'bg-white text-[#6366F1] shadow-sm' : 'text-slate-500 hover:text-slate-800'}`}
        >
          {cat.name}
        </button>
      ))}
    </div>

    {categories.map((cat, idx) => (
      <div data-tab-content={cat.id} class={`tab-content space-y-4 ${idx === 0 ? 'block' : 'hidden'}`}>
        {getCategoryItems(cat.id).map((faq) => (
          <div class="faq-item bg-white border border-slate-100 rounded-2xl overflow-hidden hover:border-[#6366F1]/30 hover:shadow-lg hover:shadow-[#6366F1]/5 transition-all duration-300">
            <button 
              class="faq-trigger cursor-pointer w-full flex items-center justify-between p-5 md:p-6 text-left outline-hidden"
              aria-expanded="false"
            >
              <span class="text-sm md:text-base font-display font-bold text-[#0F172A] pr-6 group-hover:text-[#6366F1] transition-colors">
                {faq.q}
              </span>
              <div class="faq-icon-box shrink-0 w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="faq-icon transition-transform duration-300">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </div>
            </button>
            
            <div class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
              <div class="px-5 md:px-6 pb-6">
                <div class="w-full h-px bg-slate-100 mb-4"></div>
                <p class="text-slate-600 text-xs md:text-sm leading-relaxed whitespace-pre-line">
                  {faq.a}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    ))}

    <div class="mt-12 text-center reveal">
      <div class="p-6 md:p-8 rounded-2xl bg-slate-900 text-white relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-6 text-left">
        <div class="relative z-10">
          <h4 class="text-lg font-bold mb-1">Не знайшли відповідь?</h4>
          <p class="text-slate-400 text-xs md:text-sm">Ми завжди на зв'язку, щоб допомогти вам та вашій дитині.</p>
        </div>
        <button 
          data-scroll-to="cta"
          class="cursor-pointer w-full md:w-auto text-center shrink-0 px-6 py-3.5 bg-[#6366F1] rounded-xl text-xs md:text-sm font-bold hover:bg-[#4F46E5] transition-all active:scale-95 relative z-10 shadow-lg shadow-[#6366F1]/20"
        >
          Задати особисте запитання
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Анімація скролу */
  .reveal {
    opacity: 0;
    transform: translateY(15px);
    transition: all 0.6s ease-out;
  }
  .active {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* Стан відкритого акордеону */
  .faq-item.is-open {
    border-color: rgba(99, 102, 241, 0.3);
    box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.05);
  }
  .faq-item.is-open .faq-icon {
    transform: rotate(180deg);
  }
  .faq-item.is-open .faq-icon-box {
    background-color: #6366F1;
    color: white;
  }
</style>

<script>
  function initFaqLogic() {
    // 1. Логіка Табів (Категорій)
    const tabs = document.querySelectorAll('[data-tab-target]');
    const contents = document.querySelectorAll('[data-tab-content]');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab-target');

        // Керування кнопками табів
        tabs.forEach(t => t.classList.remove('bg-white', 'text-[#6366F1]', 'shadow-sm'));
        tabs.forEach(t => t.classList.add('text-slate-500'));
        tab.classList.add('bg-white', 'text-[#6366F1]', 'shadow-sm');
        tab.classList.remove('text-slate-500');

        // Відображення контенту
        contents.forEach(c => {
          if (c.getAttribute('data-tab-content') === target) {
            c.classList.remove('hidden');
            c.classList.add('block');
          } else {
            c.classList.remove('block');
            c.classList.add('hidden');
          }
        });
      });
    });

    // 2. Логіка Акордеону (Плавний скрол висоти)
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.parentElement;
        if (!item) return;
        
        const content = item.querySelector('.faq-content') as HTMLElement;
        if (!content) return;

        const isOpen = item.classList.contains('is-open');

        // Закриваємо всі інші акордеони в межах активної вкладки
        const activeContainer = item.parentElement;
        if (activeContainer) {
          activeContainer.querySelectorAll('.faq-item').forEach(el => {
            el.classList.remove('is-open');
            const c = el.querySelector('.faq-content') as HTMLElement;
            if (c) c.style.maxHeight = '0px';
          });
        }

        // Керування станом поточного
        if (!isOpen) {
          item.classList.add('is-open');
          content.style.maxHeight = content.scrollHeight + 'px';
        } else {
          item.classList.remove('is-open');
          content.style.maxHeight = '0px';
        }
      });
    });

    // 3. Проста скрол-анімація
    const reveal = () => {
      document.querySelectorAll(".reveal").forEach(el => {
        if (el.getBoundingClientRect().top < window.innerHeight - 80) {
          el.classList.add("active");
        }
      });
    };
    window.addEventListener("scroll", reveal);
    reveal();
  }

  // Запуск логіки
  initFaqLogic();
</script>