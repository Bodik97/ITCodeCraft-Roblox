---
import content from "@/data/data.json";
const s = content.faqSection;
---

<section id="faq" class="py-20 md:py-32 bg-white relative overflow-hidden">
  <!-- Декоративні елементи на фоні -->
  <div class="absolute top-0 right-0 w-1/3 h-1/3 bg-blue-50/50 rounded-full blur-[120px] -z-10 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-1/3 bg-purple-50/50 rounded-full blur-[120px] -z-10 pointer-events-none"></div>

  <div class="container mx-auto px-4 max-w-4xl relative">
    
    <!-- Заголовок -->
    <div class="text-center mb-16 reveal">
      <div class="inline-block px-4 py-1.5 bg-[#6366F1]/5 border border-[#6366F1]/10 rounded-full mb-6">
        <span class="text-[#6366F1] text-[10px] md:text-xs font-bold uppercase tracking-widest">{s.eyebrow}</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-display font-bold text-[#0F172A] leading-tight">
        {s.title}
      </h2>
    </div>

    <!-- Акордеон -->
    <div class="space-y-4">
      {s.items.map((faq, index) => (
        <div 
          class="faq-item reveal-item group bg-white border border-slate-100 rounded-2xl overflow-hidden hover:border-[#6366F1]/30 hover:shadow-xl hover:shadow-[#6366F1]/5 transition-all duration-300"
          style={`transition-delay: ${index * 0.1}s;`}
        >
          <button 
            class="faq-trigger cursor-pointer w-full flex items-center justify-between p-6 md:p-8 text-left outline-hidden"
            aria-expanded="false"
          >
            <span class="text-base md:text-lg font-display font-bold text-[#0F172A] pr-8 group-hover:text-[#6366F1] transition-colors">
              {faq.q}
            </span>
            <div class="faq-icon-box shrink-0 w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center group-hover:bg-[#6366F1] group-hover:text-white transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="faq-icon transition-transform duration-300">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </div>
          </button>
          
          <div class="faq-content max-h-0 overflow-hidden transition-all duration-500 ease-in-out opacity-0">
            <div class="px-6 md:px-8 pb-8">
              <div class="w-full h-px bg-slate-100 mb-6"></div>
              <p class="text-slate-500 text-sm md:text-base leading-relaxed">
                {faq.a}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Додаткова допомога -->
    <div class="mt-16 text-center reveal">
      <div class="p-8 rounded-3xl bg-slate-900 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 p-4 opacity-10">
          <svg width="100" height="100" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>
        </div>
        <h4 class="text-xl font-bold mb-2">Не знайшли відповідь?</h4>
        <p class="text-slate-400 mb-6 text-sm">Ми завжди на зв'язку, щоб допомогти вам та вашій дитині.</p>
        <button 
          data-scroll-to="cta"
          class="cursor-pointer inline-flex items-center gap-2 px-8 py-4 bg-[#6366F1] rounded-xl font-bold hover:bg-[#4F46E5] transition-all active:scale-95"
        >
          Задати особисте запитання
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Анімація появи при скролі */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s ease-out;
  }
  .reveal-item {
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.6s ease-out;
  }
  .active {
    opacity: 1 !important;
    transform: translate(0) !important;
  }

  /* Акордеон стани */
  .faq-item.is-open {
    border-color: rgba(99, 102, 241, 0.4);
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.05), 0 8px 10px -6px rgb(0 0 0 / 0.05);
  }
  .faq-item.is-open .faq-content {
    max-height: 500px; /* Достатньо велике значення */
    opacity: 1;
  }
  .faq-item.is-open .faq-icon {
    transform: rotate(180deg);
  }
  .faq-item.is-open .faq-icon-box {
    background-color: #6366F1;
    color: white;
  }

  /* Для екранів 320px+ */
  @media (max-width: 480px) {
    h2 { font-size: 1.75rem !important; }
  }
</style>

<script>
  function initFaq() {
    const items = document.querySelectorAll('.faq-item');
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const parent = trigger.parentElement;
        
        // ВИПРАВЛЕННЯ: Перевіряємо, чи існує parent, перш ніж працювати з ним
        if (!parent) return;

        const isOpen = parent.classList.contains('is-open');

        // Закриваємо всі відкриті
        items.forEach(item => item.classList.remove('is-open'));

        // Відкриваємо поточний, якщо він був закритий
        if (!isOpen) {
          parent.classList.add('is-open');
        }
      });
    });

    // Скрол-анімація
    const reveal = () => {
      const reveals = document.querySelectorAll(".reveal, .reveal-item");
      reveals.forEach(el => {
        const top = el.getBoundingClientRect().top;
        if (top < window.innerHeight - 100) el.classList.add("active");
      });
    };

    window.addEventListener("scroll", reveal);
    reveal();
  }

  // Запуск
  initFaq();
</script>