---
import content from "@/data/data.json";
const { navigation, brand } = content;
---

<header id="site-header" class="site-header sticky top-0 z-50 w-full bg-[#041424] backdrop-blur">
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <div class="flex items-center gap-2 min-w-0">
      <a href={brand.homeUrl} class="min-w-0 block" aria-label={`${brand.primary}${brand.accent}`}>
        <img
          src="/logo.svg"
          alt={`${brand.primary}${brand.accent}`}
          class="h-9 w-auto object-contain xl:h-12"
          width="600"
          height="190"
          loading="eager"
          decoding="async"
        />
      </a>
    </div>
    <nav class="hidden md:flex items-center gap-5" aria-label="Навігація">
      {navigation.links.map((link) => (
        <button
          type="button"
          data-scroll-to={link.id}
          class="cursor-pointer text-sm font-medium text-white/70 hover:text-white transition-colors"
        >
          {link.label}
        </button>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <button
        type="button"
        data-scroll-to="cta"
        data-testid="button-header-cta"
        class="hidden sm:inline-flex px-5 py-2 rounded-xl font-bold text-sm btn-3d-amber"
      >
        {navigation.ctaLabel}
      </button>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="menu-toggle md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        data-label-open={navigation.openMenuLabel}
        data-label-close="Закрити меню"
        aria-label={navigation.openMenuLabel}
      >
        <span class="menu-toggle__icon" aria-hidden="true">
          <span class="menu-toggle__line"></span>
          <span class="menu-toggle__line"></span>
          <span class="menu-toggle__line"></span>
        </span>
      </button>
    </div>
  </div>

  <div id="mobile-menu-backdrop" class="mobile-menu-backdrop md:hidden" aria-hidden="true"></div>

  <div
    id="mobile-menu-panel"
    class="mobile-menu-panel md:hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-menu-title"
    aria-hidden="true"
  >
    <p id="mobile-menu-title" class="sr-only">Навігація</p>
    <div class="mobile-menu-accent" aria-hidden="true"></div>
    <nav class="mobile-menu-inner" aria-label="Навігація">
      {navigation.links.map((link, index) => (
        <button
          type="button"
          data-scroll-to={link.id}
          class="mobile-menu-link"
          style={`--item-index: ${index}`}
        >
          <span class="mobile-menu-link__dot" aria-hidden="true"></span>
          {link.label}
        </button>
      ))}
      <button
        type="button"
        data-scroll-to="cta"
        class="mobile-menu-cta btn-3d-amber"
        style={`--item-index: ${navigation.links.length}`}
      >
        {navigation.ctaLabel}
      </button>
    </nav>
  </div>
</header>

<style>
  .menu-toggle {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  @media (min-width: 768px) {
    .menu-toggle {
      display: none;
    }
  }

  .menu-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(34, 211, 238, 0.35);
    box-shadow: 0 0 0 1px rgba(34, 211, 238, 0.12);
  }

  .menu-toggle__icon {
    width: 1.125rem;
    height: 0.875rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .menu-toggle__line {
    display: block;
    height: 2px;
    width: 100%;
    border-radius: 999px;
    background: currentColor;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.2s ease;
    transform-origin: center;
  }

  .site-header.is-menu-open .menu-toggle__line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-header.is-menu-open .menu-toggle__line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .site-header.is-menu-open .menu-toggle__line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu-backdrop {
    position: fixed;
    inset: 0;
    top: 4rem;
    z-index: 40;
    background: rgba(2, 12, 22, 0.55);
    backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.35s ease,
      visibility 0.35s ease;
  }

  .site-header.is-menu-open .mobile-menu-backdrop {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-menu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 50;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    background: linear-gradient(180deg, #041424 0%, #051a2e 55%, #062238 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 24px 48px -12px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(34, 211, 238, 0.06) inset;
    transition:
      max-height 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.35s ease,
      visibility 0.35s ease;
  }

  .site-header.is-menu-open .mobile-menu-panel {
    max-height: min(92vh, 50rem);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-menu-accent {
    height: 2px;
    background: linear-gradient(90deg, #6366f1 0%, #00a2ff 50%, #fbbf24 100%);
    opacity: 0.85;
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1rem 1.25rem;
    justify-content: flex-start;
  }

  .mobile-menu-link,
  .mobile-menu-cta {
    opacity: 0;
    transform: translateY(-10px);
    transition:
      opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
    transition-delay: calc(0.05s + var(--item-index, 0) * 0.05s);
  }

  .site-header.is-menu-open .mobile-menu-link,
  .site-header.is-menu-open .mobile-menu-cta {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    min-height: 2.75rem;
    text-align: left;
    padding: 0.75rem 1rem;
    border-radius: 0.875rem;
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
  }

  .mobile-menu-link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(0, 162, 255, 0.35);
    color: #fff;
  }

  .mobile-menu-link__dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 999px;
    background: #00a2ff;
    box-shadow: 0 0 8px rgba(0, 162, 255, 0.65);
    flex-shrink: 0;
  }

  .mobile-menu-cta {
    margin-top: 0.75rem;
    width: 100%;
    min-height: 3rem;
    padding: 0.875rem 1rem;
    border-radius: 0.875rem;
    font-family: "Fredoka", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-align: center;
    cursor: pointer;
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-toggle__line,
    .mobile-menu-backdrop,
    .mobile-menu-panel,
    .mobile-menu-link,
    .mobile-menu-cta {
      transition-duration: 0.01ms !important;
      transition-delay: 0ms !important;
    }

    .mobile-menu-link,
    .mobile-menu-cta {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("mobile-menu-toggle");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const panel = document.getElementById("mobile-menu-panel");

  const openLabel = toggle?.dataset.labelOpen ?? "Відкрити меню";
  const closeLabel = toggle?.dataset.labelClose ?? "Закрити меню";

  function setMenuOpen(open) {
    header?.classList.toggle("is-menu-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    toggle?.setAttribute("aria-label", open ? closeLabel : openLabel);
    panel?.setAttribute("aria-hidden", String(!open));
    backdrop?.setAttribute("aria-hidden", String(!open));
    document.body.classList.toggle("overflow-hidden", open);
  }

  toggle?.addEventListener("click", () => {
    setMenuOpen(!header?.classList.contains("is-menu-open"));
  });

  backdrop?.addEventListener("click", () => setMenuOpen(false));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && header?.classList.contains("is-menu-open")) {
      setMenuOpen(false);
    }
  });

  document.addEventListener("mobile-menu:close", () => setMenuOpen(false));
</script>
